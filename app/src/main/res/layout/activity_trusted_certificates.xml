<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_main">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_certificates"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="?attr/actionBarSize"
        android:background="@color/background_surface"
        android:elevation="4dp"
        app:title="@string/title_trusted_certificates"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="@color/icon_main" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_certificates"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="16dp" />

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="100dp"
        android:text="@string/msg_no_trusted_certificates"
        android:textColor="@color/text_secondary"
        android:visibility="gone" />

</LinearLayout>
